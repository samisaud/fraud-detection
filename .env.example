# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy this to .env and fill in your values
# .env is in .gitignore and will NEVER be committed
# ─────────────────────────────────────────────────────────────────────────────

# DagsHub credentials (for MLflow remote tracking)
# Get these from: https://dagshub.com/user/settings/tokens
DAGSHUB_USERNAME=your_dagshub_username_here
DAGSHUB_REPO=ksa-fraud-detection
DAGSHUB_TOKEN=your_dagshub_token_here

# MLflow tracking (auto-constructed from DagsHub creds)
MLFLOW_TRACKING_USERNAME=${DAGSHUB_USERNAME}
MLFLOW_TRACKING_PASSWORD=${DAGSHUB_TOKEN}

# Google Drive DVC remote (optional — for data versioning)
# Follow: https://dvc.org/doc/user-guide/data-management/remote-storage/google-drive
# GDRIVE_CREDENTIALS_DATA=<paste service account JSON here>
